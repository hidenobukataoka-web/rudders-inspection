['dim-import-zone','spec-import-zone'].forEach((id,i)=>{
  const z=document.getElementById(id);const type=i===0?'dim':'spec';
  z.addEventListener('dragover',e=>{e.preventDefault();z.classList.add('drag-over');});
  z.addEventListener('dragleave',()=>z.classList.remove('drag-over'));
  z.addEventListener('drop',e=>{e.preventDefault();z.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f)handleSpecImport(f,type);});
});

async function handleSpecImport(file,type){
  if(!file)return;
  const ext=file.name.split('.').pop().toLowerCase();
  if(!['xlsx','xls','pdf'].includes(ext)){toast('Excel または PDF を選択してください','error');return;}
  const prog=document.getElementById(type+'-import-progress');
  const bar=document.getElementById(type+'-prog-bar');
  const msg=document.getElementById(type+'-prog-msg');
  const ps1=document.getElementById(type+'-ps1');
  const ps2=document.getElementById(type+'-ps2');
  const ps3=document.getElementById(type+'-ps3');
  prog.classList.add('show');
  ps1.classList.add('active');msg.textContent='ファイルを解析中...';bar.style.width='15%';
  let extracted='';
  try{
    if(ext==='xlsx'||ext==='xls') extracted=await extractExcel(file);
    else extracted=await toBase64(file);
    ps1.classList.replace('active','done');bar.style.width='40%';
    ps2.classList.add('active');msg.textContent='AIが仕様データを抽出中...';bar.style.width='55%';
    const result=await aiExtractSpec(file,ext,extracted,type);
    ps2.classList.replace('active','done');bar.style.width='80%';
    ps3.classList.add('active');msg.textContent='項目を生成中...';
    if(type==='dim') applyDimResult(result);
    else applySpecResult(result);
    bar.style.width='100%';
    ps3.classList.replace('active','done');
    msg.textContent='読み込み完了';
    document.getElementById(type+'-prog-dot').className='ai-dot done';
    toast('仕様書を読み込みました ✓');
  }catch(err){
    msg.textContent='エラー: '+err.message;
    document.getElementById(type+'-prog-dot').className='ai-dot error';
    toast('読み込み失敗: '+err.message,'error');
  }
}

async function extractExcel(file){
  return new Promise((res,rej)=>{
    const r=new FileReader();
    r.onload=e=>{try{const d=new Uint8Array(e.target.result);const wb=XLSX.read(d,{type:'array'});let t='';wb.SheetNames.forEach(n=>{const csv=XLSX.utils.sheet_to_csv(wb.Sheets[n]);if(csv.trim())t+=`[${n}]\n${csv}\n\n`;});res(t);}catch(err){rej(err);}};
    r.onerror=()=>rej(new Error('読み込み失敗'));r.readAsArrayBuffer(file);
  });
}
function toBase64(file){return new Promise((res,rej)=>{const r=new FileReader();r.onload=e=>res(e.target.result.split(',')[1]);r.onerror=()=>rej(new Error('読み込み失敗'));r.readAsDataURL(file);});}

async function aiExtractSpec(file,ext,extracted,type){
  let content=[];
  if(ext==='pdf') content.push({type:'document',source:{type:'base64',media_type:'application/pdf',data:extracted}});
  const pDim=`アパレル仕様書から「寸法（サイズスペック）」を抽出してください。${ext!=='pdf'?`\n【テキスト】\n${extracted.slice(0,8000)}`:''}
JSONのみ返答:{"meta":{"item_no":"","item_name":"","size":"","color":""},"dimensions":[{"part":"","method":"","spec":数値orNull,"note":""}]}`;
  const pSpec=`アパレル仕様書から「寸法以外の仕様」（刺繍・副資材・縫製・素材）を抽出してください。${ext!=='pdf'?`\n【テキスト】\n${extracted.slice(0,8000)}`:''}
JSONのみ返答:{"spec_items":[{"category":"刺繍・プリント"or"副資材"or"縫製仕様"or"素材・生地"or"その他","name":"","spec":""}]}`;
  content.push({type:'text',text:type==='dim'?pDim:pSpec});
  const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content}]})});
  const data=await res.json();
  const raw=data.content.map(c=>c.text||'').join('');
  const clean=raw.replace(/```json|```/g,'').trim();
  return JSON.parse(clean.substring(clean.indexOf('{'),clean.lastIndexOf('}')+1));
}

function applyDimResult(r){
  if(r.meta){
    if(r.meta.item_no) document.getElementById('item-no').value=r.meta.item_no;
    if(r.meta.item_name) document.getElementById('item-name').value=r.meta.item_name;
    if(r.meta.color) document.getElementById('item-color').value=r.meta.color;
  }
  const dims=r.dimensions||[];
  if(dims.length>0){document.getElementById('spec-tbody').innerHTML='';dims.forEach(d=>addSpecRow(d.part||'',d.method||'',d.spec||''));}
  const ir=document.getElementById('dim-import-result');ir.classList.add('show');
  document.getElementById('dim-ir-count').textContent=`${dims.length}項目を抽出`;
  let html='<table><thead><tr><th>計測箇所</th><th>計測方法</th><th>指示寸(cm)</th></tr></thead><tbody>';
  dims.slice(0,5).forEach(d=>{html+=`<tr><td>${d.part||'—'}</td><td>${d.method||'—'}</td><td style="text-align:right">${d.spec??'—'}</td></tr>`;});
  if(dims.length>5)html+=`<tr><td colspan="3" style="text-align:center;color:var(--text-muted)">... 他${dims.length-5}項目</td></tr>`;
  document.getElementById('dim-ir-preview').innerHTML=html+'</tbody></table>';
}

function applySpecResult(r){
  const items=r.spec_items||[];
  items.forEach(item=>specItems.push({id:Date.now()+Math.random(),cat:item.category||'その他',name:item.name,spec:item.spec,status:'',note:'',photo:null}));
  if(items.length>0) renderChecklist();
  document.getElementById('spec-import-result').style.display='block';
  document.getElementById('spec-ir-count').textContent=`${items.length}項目を抽出`;
}

