function renderDimResults(parsed,meta,tol){
  const results=parsed.inspection_results||[];const v=parsed.overall_verdict||'要確認';
  const pc=results.filter(r=>r.status==='合格').length,fc=results.filter(r=>r.status==='不合格').length,nc=results.filter(r=>r.status==='判定不可').length;
  let html=`<div class="vbanner ${v==='合格'?'vp':'vf'}"><span class="vi">${v==='合格'?'✅':'❌'}</span><div><div>${v==='合格'?'総合判定：合格':'総合判定：不合格'}</div><div style="font-size:11px;font-weight:400;opacity:0.8;margin-top:1px;">${meta.itemName} ${meta.size} ${meta.color}</div></div><div style="margin-left:auto;font-size:11px;font-family:var(--mono);font-weight:400;">${meta.date}${meta.inspector?' 担当:'+meta.inspector:''}</div></div>
  <div class="sgrid"><div class="sc scp"><div class="slb">合格</div><div class="sv">${pc}</div></div><div class="sc scf"><div class="slb">不合格</div><div class="sv">${fc}</div></div><div class="sc"><div class="slb">判定不可</div><div class="sv" style="color:var(--text-dim)">${nc}</div></div></div>
  <div class="card"><div class="card-title">寸法照合結果</div><div class="spec-wrap"><table><thead><tr><th>#</th><th>計測箇所</th><th>指示寸(cm)</th><th>実寸(cm)</th><th>差分(cm)</th><th>判定</th><th>コメント</th></tr></thead><tbody>`;
  results.forEach((r,i)=>{
    const d=r.diff!==null?parseFloat(r.diff):null,ad=d!==null?Math.abs(d):null;
    const dc=ad!==null&&ad>tol?(d>0?'color:var(--warn)':'color:var(--warn)'):'color:var(--pass)';
    const badge=r.status==='合格'?`<span class="sbadge bp">✓ 合格</span>`:r.status==='不合格'?`<span class="sbadge bf">✕ 不合格</span>`:`<span class="sbadge bw">— 不可</span>`;
    html+=`<tr><td style="color:var(--text-muted);font-family:var(--mono)">${String(i+1).padStart(2,'0')}</td><td style="font-weight:500">${r.item}</td><td style="font-family:var(--mono);text-align:right">${r.spec_value??'—'}</td><td style="font-family:var(--mono);text-align:right">${r.actual_value??'—'}</td><td style="text-align:right;font-family:var(--mono);${dc}">${d!==null?(d>=0?'+':'')+d.toFixed(1):'—'}</td><td>${badge}</td><td style="font-size:11px;color:var(--text-dim)">${r.comment||''}</td></tr>`;
  });
  html+=`</tbody></table></div></div>`;
  if(parsed.summary_comment)html+=`<div class="card"><div class="card-title">AI 総合所見</div><div class="acl">INSPECTION SUMMARY</div><div class="ai-comment">${parsed.summary_comment}</div></div>`;
  document.getElementById('result-area').innerHTML=html;
}

function renderManual(rows,tol,meta){
  const area=document.getElementById('result-area');
  let html=`<div class="card"><div class="card-title">手動実寸入力モード</div><div class="spec-wrap"><table><thead><tr><th>#</th><th>計測箇所</th><th>指示寸(cm)</th><th>実寸入力(cm)</th><th>判定</th></tr></thead><tbody>`;
  rows.forEach((r,i)=>{html+=`<tr><td style="color:var(--text-muted);font-family:var(--mono)">${String(i+1).padStart(2,'0')}</td><td style="font-weight:500">${r.part}</td><td style="font-family:var(--mono);text-align:right">${r.spec??'—'}</td><td><input type="number" step="0.1" placeholder="実寸" data-spec="${r.spec}" data-tol="${tol}" oninput="calcD(this,${i})" style="width:82px;text-align:right"></td><td id="j${i}"><span class="sbadge bw">—</span></td></tr>`;});
  html+=`</tbody></table></div></div>`;area.innerHTML+=html;
}
function calcD(inp,idx){
  const sp=parseFloat(inp.dataset.spec),tl=parseFloat(inp.dataset.tol),ac=parseFloat(inp.value);
  const jc=document.getElementById('j'+idx);if(!jc)return;
  if(isNaN(ac)||isNaN(sp)){jc.innerHTML=`<span class="sbadge bw">—</span>`;return;}
  const d=ac-sp,ok=Math.abs(d)<=tl;
  jc.innerHTML=ok?`<span class="sbadge bp">✓ 合格</span>`:`<span class="sbadge bf">✕ 不合格 (${d>=0?'+':''}${d.toFixed(1)}cm)</span>`;
}

