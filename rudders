<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RUDDERS 検品システム</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Noto+Sans+JP:wght@300;400;500;700&family=Syne:wght@700;800&display=swap');
:root{
  --bg:#0d0d0f;--surface:#141416;--surface2:#1c1c1f;--border:#2a2a2e;
  --accent:#e8c87a;--accent-dim:rgba(232,200,122,0.12);--accent-dim2:rgba(232,200,122,0.06);
  --pass:#4caf78;--pass-dim:rgba(76,175,120,0.12);
  --fail:#e05252;--fail-dim:rgba(224,82,82,0.12);
  --warn:#e8a84a;--warn-dim:rgba(232,168,74,0.12);
  --blue:#4a90d9;
  --text:#e8e8ea;--text-dim:#8a8a8f;--text-muted:#55555a;
  --mono:'DM Mono',monospace;--sans:'Noto Sans JP',sans-serif;--syne:'Syne',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;font-size:13px;line-height:1.6;}

/* ── HEADER ── */
header{border-bottom:1px solid var(--border);padding:0 28px;height:54px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:rgba(13,13,15,0.93);backdrop-filter:blur(12px);z-index:100;}
.logo{font-family:var(--syne);font-size:13px;font-weight:800;letter-spacing:0.16em;display:flex;align-items:center;gap:8px;}
.logo em{color:var(--accent);font-style:normal;}
.hdr-r{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10px;color:var(--text-muted);}
#clock{color:var(--accent);}

/* ── LAYOUT ── */
.container{max-width:1100px;margin:0 auto;padding:28px 20px 80px;}
.page-title{margin-bottom:22px;}
.page-title h1{font-size:20px;font-weight:700;letter-spacing:-0.01em;margin-bottom:3px;}
.page-title p{font-size:11px;color:var(--text-dim);font-family:var(--mono);letter-spacing:0.08em;}

/* ── MODE TABS ── */
.mode-tabs{display:flex;border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:24px;background:var(--surface);}
.mode-tab{flex:1;padding:13px 10px;border:none;background:none;color:var(--text-muted);font-family:var(--mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:all 0.2s;border-right:1px solid var(--border);display:flex;align-items:center;justify-content:center;gap:6px;}
.mode-tab:last-child{border-right:none;}
.mode-tab.active{background:var(--accent-dim);color:var(--accent);}
.mode-tab .tab-icon{font-size:14px;}
.mode-panel{display:none;animation:fadeIn 0.25s ease;}
.mode-panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}

/* ── STEP TABS ── */
.steps{display:flex;margin-bottom:22px;border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.step-tab{flex:1;padding:11px 12px;background:var(--surface);border:none;color:var(--text-muted);font-family:var(--mono);font-size:10px;letter-spacing:0.08em;cursor:pointer;transition:all 0.2s;border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:flex-start;gap:2px;}
.step-tab:last-child{border-right:none;}
.step-tab.active{background:var(--accent-dim);color:var(--accent);border-bottom:2px solid var(--accent);}
.step-tab.done{color:var(--pass);}
.step-tab.done .snum::after{content:' ✓';}
.snum{font-size:9px;opacity:0.55;text-transform:uppercase;}
.slabel{font-size:10px;text-transform:uppercase;}
.panel{display:none;animation:fadeIn 0.25s ease;}
.panel.active{display:block;}

/* ── CARD ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:22px;margin-bottom:14px;}
.card-title{font-size:10px;font-family:var(--mono);letter-spacing:0.15em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.card-title::before{content:'';display:inline-block;width:3px;height:12px;background:var(--accent);border-radius:2px;}

/* ── FORM ── */
.fgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:11px;}
.fg{display:flex;flex-direction:column;gap:5px;}
.fg label{font-size:10px;font-family:var(--mono);letter-spacing:0.1em;color:var(--text-dim);text-transform:uppercase;}
input[type="text"],input[type="number"],select,textarea{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 11px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none;transition:border-color 0.2s;width:100%;}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-dim);}
select option{background:var(--surface2);}
.tol-row{display:flex;align-items:center;gap:12px;margin-top:11px;padding:9px 13px;background:var(--accent-dim2);border:1px solid var(--border);border-radius:6px;}
.tol-row label{font-family:var(--mono);font-size:10px;color:var(--text-dim);letter-spacing:0.1em;text-transform:uppercase;white-space:nowrap;}
.tol-row input{width:82px;}
.tol-row span{font-family:var(--mono);font-size:11px;color:var(--text-dim);}

/* ── TABLE ── */
.spec-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:12px;}
thead th{background:var(--surface2);padding:9px 13px;text-align:left;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-dim);border-bottom:1px solid var(--border);white-space:nowrap;}
tbody td{padding:9px 13px;border-bottom:1px solid var(--border);vertical-align:middle;}
tbody tr:hover td{background:var(--accent-dim2);}
tbody td input,tbody td select{padding:5px 9px;font-size:12px;}
.btn-icon{background:none;border:1px solid var(--border);color:var(--text-muted);width:27px;height:27px;border-radius:4px;cursor:pointer;font-size:13px;display:inline-flex;align-items:center;justify-content:center;transition:all 0.2s;}
.btn-icon:hover{border-color:var(--fail);color:var(--fail);background:var(--fail-dim);}

/* ── BUTTONS ── */
.btn{padding:9px 18px;border-radius:7px;border:none;font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:all 0.2s;display:inline-flex;align-items:center;gap:6px;}
.btn-p{background:var(--accent);color:#0d0d0f;font-weight:500;}
.btn-p:hover{background:#f0d490;box-shadow:0 0 14px rgba(232,200,122,0.3);}
.btn-s{background:var(--surface2);color:var(--text-dim);border:1px solid var(--border);}
.btn-s:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-dim);}
.btn-green{background:var(--pass-dim);color:var(--pass);border:1px solid rgba(76,175,120,0.3);}
.btn-green:hover{background:rgba(76,175,120,0.2);border-color:var(--pass);}
.btn:disabled{opacity:0.4;cursor:not-allowed;}
.btn-row{display:flex;gap:9px;margin-top:18px;flex-wrap:wrap;align-items:center;}

/* ── UPLOAD ── */
.upload-zone{border:2px dashed var(--border);border-radius:10px;padding:28px 18px;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--surface2);position:relative;overflow:hidden;}
.upload-zone:hover,.upload-zone.drag-over{border-color:var(--accent);background:var(--accent-dim2);}
.upload-zone input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.uicon{font-size:24px;margin-bottom:7px;}
.utext{font-size:12px;color:var(--text-dim);font-family:var(--mono);letter-spacing:0.06em;}
.usub{font-size:10px;color:var(--text-muted);margin-top:4px;}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:8px;margin-top:10px;}
.pitem{position:relative;border:1px solid var(--border);border-radius:7px;overflow:hidden;aspect-ratio:1;background:var(--surface2);}
.pitem img{width:100%;height:100%;object-fit:cover;cursor:pointer;transition:opacity 0.2s;}
.pitem img:hover{opacity:0.85;}
.prm{position:absolute;top:5px;right:5px;background:rgba(13,13,15,0.8);border:1px solid var(--border);color:var(--fail);width:19px;height:19px;border-radius:3px;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;}
.plbl{position:absolute;bottom:0;left:0;right:0;background:rgba(13,13,15,0.7);padding:3px 5px;font-family:var(--mono);font-size:9px;color:var(--text-dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* ── IMPORT ZONE ── */
.import-zone{border:2px dashed var(--border);border-radius:10px;overflow:hidden;background:var(--surface2);transition:all 0.2s;cursor:pointer;position:relative;}
.import-zone:hover,.import-zone.drag-over{border-color:var(--accent);background:var(--accent-dim2);}
.import-zone input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;z-index:2;}
.import-inner{padding:26px 18px;text-align:center;pointer-events:none;}
.import-icon{font-size:26px;margin-bottom:8px;}
.import-title{font-family:var(--mono);font-size:12px;color:var(--text-dim);letter-spacing:0.08em;margin-bottom:4px;}
.import-sub{font-size:11px;color:var(--text-muted);}
.format-badges{display:flex;gap:6px;justify-content:center;margin-top:9px;}
.fbadge{padding:2px 9px;border-radius:99px;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;border:1px solid var(--border);color:var(--text-muted);}
.fbadge.excel{border-color:rgba(76,175,120,0.4);color:var(--pass);}
.fbadge.pdf{border-color:rgba(232,168,74,0.4);color:var(--warn);}
.import-progress{display:none;padding:14px 18px;border-top:1px solid var(--border);background:var(--surface2);}
.import-progress.show{display:block;}
.prog-label{font-family:var(--mono);font-size:10px;letter-spacing:0.1em;color:var(--text-dim);text-transform:uppercase;margin-bottom:7px;display:flex;align-items:center;gap:8px;}
.prog-bar-wrap{background:var(--border);border-radius:99px;height:3px;overflow:hidden;}
.prog-bar{height:100%;background:var(--accent);border-radius:99px;transition:width 0.4s ease;width:0%;}
.prog-steps{display:flex;gap:6px;margin-top:9px;flex-wrap:wrap;}
.prog-step{padding:2px 9px;border-radius:99px;font-family:var(--mono);font-size:10px;border:1px solid var(--border);color:var(--text-muted);transition:all 0.3s;}
.prog-step.active{border-color:var(--accent);color:var(--accent);background:var(--accent-dim);}
.prog-step.done{border-color:var(--pass);color:var(--pass);background:var(--pass-dim);}
.import-result{margin-top:12px;display:none;}
.import-result.show{display:block;}
.import-result-header{display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:var(--pass-dim);border:1px solid rgba(76,175,120,0.3);border-radius:7px 7px 0 0;}
.ir-label{font-family:var(--mono);font-size:10px;letter-spacing:0.1em;color:var(--pass);text-transform:uppercase;}
.ir-count{font-family:var(--mono);font-size:11px;color:var(--pass);}
.import-preview-table{border:1px solid var(--border);border-top:none;border-radius:0 0 7px 7px;overflow:hidden;}
.import-preview-table table{font-size:11px;}
.import-preview-table thead th{font-size:9px;padding:7px 11px;}
.import-preview-table tbody td{padding:7px 11px;color:var(--text-dim);}
.import-preview-table tbody td:first-child{color:var(--text);}
.import-preview-table tbody tr:last-child td{border-bottom:none;}

/* ── AI STATUS ── */
.ai-status{display:flex;align-items:center;gap:10px;padding:11px 15px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;margin-bottom:13px;font-family:var(--mono);font-size:11px;color:var(--text-dim);}
.ai-dot{width:7px;height:7px;border-radius:50%;background:var(--text-muted);flex-shrink:0;}
.ai-dot.thinking{background:var(--warn);animation:pulse 1s infinite;}
.ai-dot.done{background:var(--pass);}
.ai-dot.error{background:var(--fail);}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}

/* ── BADGES ── */
.sbadge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:99px;font-size:10px;font-family:var(--mono);letter-spacing:0.08em;text-transform:uppercase;font-weight:500;white-space:nowrap;}
.bp{background:var(--pass-dim);color:var(--pass);}
.bf{background:var(--fail-dim);color:var(--fail);}
.bw{background:var(--warn-dim);color:var(--warn);}
.sgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:16px;}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:14px 18px;display:flex;flex-direction:column;gap:4px;}
.slb{font-family:var(--mono);font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-muted);}
.sv{font-family:var(--mono);font-size:24px;font-weight:500;line-height:1;}
.sc.scp{border-color:rgba(76,175,120,0.3);} .sc.scp .sv{color:var(--pass);}
.sc.scf{border-color:rgba(224,82,82,0.3);} .sc.scf .sv{color:var(--fail);}
.vbanner{border-radius:9px;padding:14px 22px;display:flex;align-items:center;gap:14px;margin-bottom:16px;font-weight:700;font-size:14px;letter-spacing:0.04em;}
.vbanner.vp{background:var(--pass-dim);border:1px solid rgba(76,175,120,0.3);color:var(--pass);}
.vbanner.vf{background:var(--fail-dim);border:1px solid rgba(224,82,82,0.3);color:var(--fail);}
.vi{font-size:20px;}
.ai-comment{background:var(--surface2);border-left:3px solid var(--accent);border-radius:0 7px 7px 0;padding:12px 14px;margin-top:12px;font-size:12px;color:var(--text-dim);line-height:1.8;white-space:pre-wrap;}
.acl{font-family:var(--mono);font-size:9px;letter-spacing:0.15em;color:var(--accent);text-transform:uppercase;margin-bottom:6px;}

/* ── SPEC CHECK ── */
.cc{margin-bottom:16px;}
.cc-title{font-family:var(--mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-dim);padding:8px 13px;background:var(--surface2);border:1px solid var(--border);border-radius:6px 6px 0 0;display:flex;align-items:center;gap:7px;}
.ci{border:1px solid var(--border);border-top:none;padding:10px 13px;background:var(--surface);display:grid;grid-template-columns:1fr 200px 125px 1fr;gap:9px;align-items:center;transition:background 0.15s;}
.ci:last-child{border-radius:0 0 6px 6px;}
.ci:hover{background:var(--accent-dim2);}
.ciname{font-size:12px;font-weight:500;}
.cispec{font-size:11px;color:var(--text-dim);font-family:var(--mono);margin-top:2px;}
.cispec em{color:var(--accent);font-style:normal;}
.jbtns{display:flex;gap:4px;}
.jbtn{flex:1;padding:5px 5px;border-radius:4px;border:1px solid var(--border);background:none;color:var(--text-muted);font-family:var(--mono);font-size:10px;cursor:pointer;transition:all 0.15s;text-transform:uppercase;}
.jbtn.jp.sel{background:var(--pass-dim);border-color:var(--pass);color:var(--pass);}
.jbtn.jf.sel{background:var(--fail-dim);border-color:var(--fail);color:var(--fail);}
.jbtn.jn.sel{background:var(--warn-dim);border-color:var(--warn);color:var(--warn);}
.jbtn:hover{border-color:var(--accent);}
.photo-attach-btn{background:none;border:1px dashed var(--border);border-radius:4px;color:var(--text-muted);font-family:var(--mono);font-size:10px;padding:4px 8px;cursor:pointer;transition:all 0.15s;white-space:nowrap;}
.photo-attach-btn:hover{border-color:var(--accent);color:var(--accent);}
.photo-attach-btn.has{border-color:var(--pass);color:var(--pass);border-style:solid;}

/* ══════════════════════════════════════
   AI 採寸タブ専用スタイル
══════════════════════════════════════ */
.measure-hero{
  background:linear-gradient(135deg,rgba(232,200,122,0.06) 0%,rgba(13,13,15,0) 60%);
  border:1px solid var(--border);border-radius:12px;padding:28px 24px;margin-bottom:18px;
  display:flex;align-items:center;gap:20px;
}
.measure-hero-icon{font-size:42px;flex-shrink:0;}
.measure-hero h2{font-family:var(--syne);font-size:18px;font-weight:700;letter-spacing:0.02em;margin-bottom:5px;}
.measure-hero p{font-size:12px;color:var(--text-dim);line-height:1.7;}

.scale-options{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;}
.scale-opt{border:1px solid var(--border);border-radius:7px;padding:12px 8px;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--surface2);}
.scale-opt:hover{border-color:rgba(255,255,255,0.25);}
.scale-opt.sel{border-color:var(--accent);background:var(--accent-dim);}
.scale-icon{font-size:18px;margin-bottom:5px;}
.scale-name{font-size:10px;color:var(--text-dim);font-family:var(--mono);letter-spacing:0.06em;}
.scale-size{font-size:11px;color:var(--text);font-family:var(--mono);margin-top:2px;}
.scale-opt.sel .scale-name,.scale-opt.sel .scale-size{color:var(--text);}
#custom-scale-wrap{display:none;gap:8px;align-items:center;margin-bottom:14px;}
#custom-scale-wrap.show{display:flex;}
.scale-input{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none;}
.scale-input:focus{border-color:var(--accent);}
.scale-unit{font-size:11px;color:var(--text-dim);white-space:nowrap;font-family:var(--mono);}

/* 計測部位チェックリスト */
.parts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:7px;margin-bottom:16px;}
.part-chip{border:1px solid var(--border);border-radius:6px;padding:8px 12px;cursor:pointer;transition:all 0.15s;background:var(--surface2);display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;color:var(--text-dim);}
.part-chip.sel{border-color:var(--accent);background:var(--accent-dim);color:var(--text);}
.part-chip .pc-dot{width:6px;height:6px;border-radius:50%;background:var(--border);flex-shrink:0;transition:background 0.15s;}
.part-chip.sel .pc-dot{background:var(--accent);}

/* 採寸結果 */
.measure-result-wrap{border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:16px;}
#measure-canvas{width:100%;display:block;max-height:400px;object-fit:contain;background:#0a0a0a;}
.measure-canvas-legend{padding:10px 14px;background:var(--surface);border-top:1px solid var(--border);display:flex;flex-wrap:wrap;gap:10px;}
.legend-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text-dim);font-family:var(--mono);}
.legend-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}

.measure-table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:14px;}
.mtable-header{display:grid;grid-template-columns:1fr 70px 90px 60px;padding:9px 14px;font-size:9px;letter-spacing:0.12em;color:var(--text-muted);text-transform:uppercase;border-bottom:1px solid var(--border);font-family:var(--mono);}
.mrow{display:grid;grid-template-columns:1fr 70px 90px 60px;padding:11px 14px;border-bottom:1px solid var(--border);align-items:center;transition:background 0.15s;}
.mrow:last-child{border-bottom:none;}
.mrow:hover{background:var(--surface2);}
.mrow-name{display:flex;align-items:center;gap:8px;font-size:12px;}
.mrow-color{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.mrow-px{font-size:11px;color:var(--text-muted);text-align:right;font-family:var(--mono);}
.mrow-cm{font-size:13px;font-weight:500;text-align:right;color:var(--pass);font-family:var(--mono);}
.mrow-cm.approx{color:var(--warn);}
.conf-badge{display:inline-block;font-size:8px;letter-spacing:0.06em;padding:1px 5px;border-radius:2px;margin-left:5px;}
.conf-high{background:var(--pass-dim);color:var(--pass);}
.conf-mid{background:var(--warn-dim);color:var(--warn);}
.conf-low{background:var(--fail-dim);color:var(--fail);}

.scale-note{border-left:2px solid var(--border);padding:10px 14px;font-size:11px;color:var(--text-dim);letter-spacing:0.04em;line-height:1.7;margin-bottom:13px;background:var(--surface);border-radius:0 6px 6px 0;font-family:var(--mono);}
.scale-note.ok{border-color:var(--pass);}
.scale-note.warn{border-color:var(--warn);}

/* 取り込みバナー */
.import-banner{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:14px 18px;background:linear-gradient(90deg,rgba(76,175,120,0.1),rgba(76,175,120,0.04));border:1px solid rgba(76,175,120,0.3);border-radius:9px;margin-bottom:16px;flex-wrap:wrap;}
.import-banner-text{font-size:12px;color:var(--pass);font-family:var(--mono);}
.import-banner-sub{font-size:11px;color:var(--text-dim);margin-top:2px;}

/* analyze log */
.analyze-log{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:14px;font-size:10px;color:var(--text-dim);letter-spacing:0.04em;line-height:2;min-height:70px;font-family:var(--mono);margin-top:16px;max-height:160px;overflow-y:auto;}
.log-line{display:flex;align-items:center;gap:7px;}
.log-line::before{content:'›';color:var(--accent);}
.analyze-spinner{width:40px;height:40px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 18px;}
@keyframes spin{to{transform:rotate(360deg);}}

/* ── LIGHTBOX ── */
#lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:999;align-items:center;justify-content:center;}
#lightbox.open{display:flex;}
#lightbox img{max-width:90vw;max-height:90vh;border-radius:6px;}
#lbclose{position:absolute;top:18px;right:22px;background:none;border:1px solid var(--border);color:var(--text);width:34px;height:34px;border-radius:50%;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;}

/* ── TOAST ── */
#toast{position:fixed;bottom:22px;right:22px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:11px 16px;font-family:var(--mono);font-size:11px;color:var(--text);z-index:200;transform:translateY(70px);opacity:0;transition:all 0.3s;max-width:300px;}
#toast.show{transform:translateY(0);opacity:1;}
#toast.success{border-color:rgba(76,175,120,0.4);color:var(--pass);}
#toast.error{border-color:rgba(224,82,82,0.4);color:var(--fail);}

.empty-state{text-align:center;padding:38px 20px;color:var(--text-muted);font-family:var(--mono);font-size:11px;letter-spacing:0.1em;}
.empty-state .ei{font-size:26px;margin-bottom:9px;opacity:0.4;}

@media(max-width:640px){.steps,.mode-tabs{flex-direction:column;}.sgrid{grid-template-columns:1fr 1fr;}.ci{grid-template-columns:1fr;}.container{padding:18px 14px;}.scale-options{grid-template-columns:repeat(2,1fr);}.parts-grid{grid-template-columns:repeat(2,1fr);}}
</style>
</head>
<body>

<header>
  <div class="logo">RUDDERS <em>·</em> 検品システム</div>
  <div class="hdr-r"><span id="clock">--:--:--</span><span style="color:var(--text-muted)">JST</span></div>
</header>
<div id="lightbox"><button id="lbclose">✕</button><img id="lbimg" src="" alt=""></div>
<div id="toast"></div>

<div class="container">
  <div class="page-title">
    <h1>仕様書 × 検品写真 照合ツール</h1>
    <p>AI-POWERED INSPECTION & AUTO-MEASUREMENT · OEM QUALITY CONTROL</p>
  </div>

  <div class="mode-tabs">
    <button class="mode-tab active" onclick="switchMode('measure')"><span class="tab-icon">📐</span>AI採寸</button>
    <button class="mode-tab" onclick="switchMode('dim')"><span class="tab-icon">📏</span>寸法検品</button>
    <button class="mode-tab" onclick="switchMode('spec')"><span class="tab-icon">🔍</span>仕様チェック</button>
    <button class="mode-tab" onclick="switchMode('sum')"><span class="tab-icon">📋</span>総合レポート</button>
  </div>

  <!-- ════════════════════════════════════
       MODE: AI 採寸
  ════════════════════════════════════ -->
  <div class="mode-panel active" id="mode-measure">

    <div class="measure-hero">
      <div class="measure-hero-icon">📐</div>
      <div>
        <h2>AI 自動採寸</h2>
        <p>服の写真を1枚アップロードするだけで、着丈・身幅・袖丈など8部位の寸法を自動で読み取ります。<br>メジャーや基準スケールを一緒に写すと精度が上がります。</p>
      </div>
    </div>

    <!-- Step 1: 写真 -->
    <div class="card">
      <div class="card-title">服の写真をアップロード</div>
      <div class="upload-zone" id="m-upload-zone">
        <input type="file" id="m-file-input" accept="image/*" onchange="handleMeasureFile(this.files[0])">
        <div class="uicon">📷</div>
        <div class="utext">タップして撮影 / 画像を選択</div>
        <div class="usub">平置きで服全体が映るように · メジャーや名刺を一緒に写すと高精度</div>
      </div>
      <div id="m-preview-wrap" style="display:none;margin-top:12px;position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--border);">
        <img id="m-preview-img" style="width:100%;max-height:300px;object-fit:contain;background:#0a0a0a;display:block;" alt="preview">
        <button onclick="resetMeasure()" style="position:absolute;top:8px;right:8px;background:rgba(13,13,15,0.85);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:10px;padding:5px 10px;border-radius:4px;cursor:pointer;letter-spacing:0.06em;">変更</button>
      </div>
    </div>

    <!-- Step 2: スケール -->
    <div class="card">
      <div class="card-title">基準スケール（精度向上）</div>
      <p style="font-size:11px;color:var(--text-dim);margin-bottom:12px;">写真に写っているスケールアイテムを選択すると計測精度が上がります。スケールなしでもAIが推定します。</p>
      <div class="scale-options">
        <div class="scale-opt" data-scale-id="none" data-scale-cm="0" onclick="selectScale(this)">
          <div class="scale-icon">🤖</div>
          <div class="scale-name">スケールなし</div>
          <div class="scale-size">AI推定</div>
        </div>
        <div class="scale-opt sel" data-scale-id="card" data-scale-cm="8.56" onclick="selectScale(this)">
          <div class="scale-icon">💳</div>
          <div class="scale-name">名刺 / クレカ</div>
          <div class="scale-size">長辺 8.56cm</div>
        </div>
        <div class="scale-opt" data-scale-id="a4" data-scale-cm="29.7" onclick="selectScale(this)">
          <div class="scale-icon">📄</div>
          <div class="scale-name">A4用紙</div>
          <div class="scale-size">長辺 29.7cm</div>
        </div>
        <div class="scale-opt" data-scale-id="custom" data-scale-cm="0" onclick="selectScale(this)">
          <div class="scale-icon">📏</div>
          <div class="scale-name">カスタム</div>
          <div class="scale-size">任意のcm</div>
        </div>
      </div>
      <div id="custom-scale-wrap">
        <input class="scale-input" id="custom-scale-input" type="number" placeholder="例: 30" min="1" max="200" step="0.1">
        <span class="scale-unit">cm</span>
      </div>
    </div>

    <!-- Step 3: 計測部位 -->
    <div class="card">
      <div class="card-title">計測部位の選択</div>
      <div class="parts-grid" id="parts-grid">
        <!-- rendered by JS -->
      </div>
      <div style="display:flex;gap:7px;margin-top:4px;">
        <button class="btn btn-s" onclick="selectAllParts(true)" style="font-size:10px;padding:6px 12px;">全選択</button>
        <button class="btn btn-s" onclick="selectAllParts(false)" style="font-size:10px;padding:6px 12px;">全解除</button>
      </div>
    </div>

    <!-- Analyze button -->
    <div id="m-error-box" style="display:none;background:var(--fail-dim);border:1px solid rgba(224,82,82,0.3);border-radius:7px;padding:13px;margin-bottom:13px;">
      <div id="m-error-msg" style="font-size:11px;color:var(--fail);font-family:var(--mono);letter-spacing:0.04em;"></div>
    </div>

    <div id="m-analyze-area" style="display:none;">
      <div class="card" style="text-align:center;padding:32px;">
        <div class="analyze-spinner"></div>
        <div style="font-family:var(--syne);font-size:15px;font-weight:700;margin-bottom:6px;">AI が採寸中...</div>
        <div style="font-size:11px;color:var(--text-dim);">写真を解析し、各部位の寸法を計算しています</div>
        <div class="analyze-log" id="m-analyze-log"></div>
      </div>
    </div>

    <div id="m-result-area" style="display:none;">
      <!-- canvas + table rendered by JS -->
    </div>

    <div class="btn-row" id="m-btn-row">
      <button class="btn btn-p" id="m-run-btn" onclick="runMeasure()" disabled>📐 AI採寸を実行</button>
    </div>
  </div>

  <!-- ════════════════════════════════════
       MODE: 寸法検品
  ════════════════════════════════════ -->
  <div class="mode-panel" id="mode-dim">
    <div class="steps">
      <button class="step-tab active"><span class="snum">Step 01</span><span class="slabel">基本情報</span></button>
      <button class="step-tab"><span class="snum">Step 02</span><span class="slabel">仕様入力</span></button>
      <button class="step-tab"><span class="snum">Step 03</span><span class="slabel">写真添付</span></button>
      <button class="step-tab"><span class="snum">Step 04</span><span class="slabel">AI判定</span></button>
    </div>

    <div class="panel active" id="p1">
      <div class="card">
        <div class="card-title">案件情報</div>
        <div class="fgrid">
          <div class="fg"><label>品番</label><input type="text" id="item-no" placeholder="e.g. RD-2024-001"></div>
          <div class="fg"><label>品名</label><input type="text" id="item-name" placeholder="e.g. テーラードジャケット"></div>
          <div class="fg"><label>サイズ</label><select id="item-size"><option value="">選択</option><option>XS</option><option>S</option><option>M</option><option>L</option><option>XL</option><option>XXL</option><option>FREE</option></select></div>
          <div class="fg"><label>カラー</label><input type="text" id="item-color" placeholder="e.g. オフホワイト"></div>
          <div class="fg"><label>サンプル種別</label><select id="sample-type"><option value="">選択</option><option>PP Sample</option><option>Size Set</option><option>TOP Sample</option><option>Bulk</option></select></div>
          <div class="fg"><label>検品担当者</label><input type="text" id="inspector" placeholder="氏名"></div>
        </div>
        <div class="tol-row">
          <label>許容範囲 (±)</label>
          <input type="number" id="tolerance" value="1.0" step="0.1" min="0.1" max="5">
          <span>cm</span>
        </div>
      </div>
      <div class="btn-row"><button class="btn btn-p" onclick="goStep(2)">次へ → 仕様入力</button></div>
    </div>

    <div class="panel" id="p2">
      <!-- AI採寸からの取り込みバナー（採寸結果がある場合に表示） -->
      <div class="import-banner" id="measure-import-banner" style="display:none;">
        <div>
          <div class="import-banner-text">📐 AI採寸の結果を取り込めます</div>
          <div class="import-banner-sub">採寸タブで計測した実寸値を、指示寸として一括インポートできます</div>
        </div>
        <button class="btn btn-green" onclick="importFromMeasure()">採寸結果を取り込む</button>
      </div>

      <div class="card">
        <div class="card-title">仕様書から自動読み込み</div>
        <div class="import-zone" id="dim-import-zone">
          <input type="file" id="dim-spec-file" accept=".xlsx,.xls,.pdf" onchange="handleSpecImport(this.files[0],'dim')">
          <div class="import-inner">
            <div class="import-icon">📄</div>
            <div class="import-title">仕様書をドロップ、またはクリックして選択</div>
            <div class="import-sub">AIが自動で寸法データを抽出します</div>
            <div class="format-badges"><span class="fbadge excel">Excel (.xlsx)</span><span class="fbadge pdf">PDF</span></div>
          </div>
          <div class="import-progress" id="dim-import-progress">
            <div class="prog-label"><div class="ai-dot thinking" id="dim-prog-dot"></div><span id="dim-prog-msg">読み込み中...</span></div>
            <div class="prog-bar-wrap"><div class="prog-bar" id="dim-prog-bar"></div></div>
            <div class="prog-steps"><span class="prog-step" id="dim-ps1">ファイル解析</span><span class="prog-step" id="dim-ps2">AI抽出</span><span class="prog-step" id="dim-ps3">テーブル生成</span></div>
          </div>
        </div>
        <div class="import-result" id="dim-import-result">
          <div class="import-result-header"><span class="ir-label">✓ 自動読み込み完了</span><span class="ir-count" id="dim-ir-count"></span></div>
          <div class="import-preview-table" id="dim-ir-preview"></div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">寸法仕様 — 確認・編集</div>
        <div class="spec-wrap">
          <table><thead><tr><th>#</th><th>計測箇所</th><th>計測方法</th><th>指示寸(cm)</th><th>備考</th><th></th></tr></thead>
          <tbody id="spec-tbody"></tbody></table>
        </div>
        <div style="display:flex;gap:7px;margin-top:11px;flex-wrap:wrap;">
          <button class="btn btn-s" onclick="addSpecRow()">＋ 行を追加</button>
          <button class="btn btn-s" onclick="loadPreset('jacket')">ジャケット</button>
          <button class="btn btn-s" onclick="loadPreset('shirt')">シャツ</button>
          <button class="btn btn-s" onclick="loadPreset('pants')">パンツ</button>
          <button class="btn btn-s" onclick="loadPreset('tshirt')">Tシャツ</button>
        </div>
      </div>
      <div class="btn-row">
        <button class="btn btn-s" onclick="goStep(1)">← 戻る</button>
        <button class="btn btn-p" onclick="goStep(3)">次へ → 写真添付</button>
      </div>
    </div>

    <div class="panel" id="p3">
      <div class="card">
        <div class="card-title">検品写真アップロード</div>
        <div class="upload-zone" id="dz">
          <input type="file" id="photo-input" multiple accept="image/*" onchange="handlePhotos(this.files,'dim')">
          <div class="uicon">📷</div>
          <div class="utext">写真をドロップ、またはクリックして選択</div>
          <div class="usub">JPG / PNG / HEIC · メジャー付きで撮影</div>
        </div>
        <div class="pgrid" id="pgrid"></div>
      </div>
      <div class="btn-row">
        <button class="btn btn-s" onclick="goStep(2)">← 戻る</button>
        <button class="btn btn-p" onclick="goStep(4);runInspection()">AI判定を実行 →</button>
      </div>
    </div>

    <div class="panel" id="p4">
      <div id="result-area"><div class="empty-state"><div class="ei">⏳</div>AI判定を待機中...</div></div>
      <div class="btn-row" id="result-actions" style="display:none;">
        <button class="btn btn-s" onclick="goStep(1)">← 最初から</button>
        <button class="btn btn-s" onclick="window.print()">🖨 印刷</button>
        <button class="btn btn-p" onclick="exportCSV('dim')">⬇ CSV出力</button>
      </div>
    </div>
  </div>

  <!-- ════════════════════════════════════
       MODE: 仕様チェック
  ════════════════════════════════════ -->
  <div class="mode-panel" id="mode-spec">
    <div class="card">
      <div class="card-title">仕様書から自動読み込み</div>
      <div class="import-zone" id="spec-import-zone">
        <input type="file" id="spec-spec-file" accept=".xlsx,.xls,.pdf" onchange="handleSpecImport(this.files[0],'spec')">
        <div class="import-inner">
          <div class="import-icon">📄</div>
          <div class="import-title">仕様書をドロップ、またはクリックして選択</div>
          <div class="import-sub">刺繍位置・副資材・縫製仕様などを自動抽出</div>
          <div class="format-badges"><span class="fbadge excel">Excel (.xlsx)</span><span class="fbadge pdf">PDF</span></div>
        </div>
        <div class="import-progress" id="spec-import-progress">
          <div class="prog-label"><div class="ai-dot thinking" id="spec-prog-dot"></div><span id="spec-prog-msg">読み込み中...</span></div>
          <div class="prog-bar-wrap"><div class="prog-bar" id="spec-prog-bar"></div></div>
          <div class="prog-steps"><span class="prog-step" id="spec-ps1">ファイル解析</span><span class="prog-step" id="spec-ps2">AI抽出</span><span class="prog-step" id="spec-ps3">チェックリスト生成</span></div>
        </div>
      </div>
      <div class="import-result" id="spec-import-result" style="margin-top:11px;display:none;">
        <div class="import-result-header"><span class="ir-label">✓ 仕様項目を自動生成</span><span class="ir-count" id="spec-ir-count"></span></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">プリセットで追加</div>
      <div style="display:flex;gap:7px;flex-wrap:wrap;">
        <button class="btn btn-s" onclick="loadSpecPreset('emb')">🪡 刺繍・プリント</button>
        <button class="btn btn-s" onclick="loadSpecPreset('trim')">🔘 副資材</button>
        <button class="btn btn-s" onclick="loadSpecPreset('sew')">🧵 縫製仕様</button>
        <button class="btn btn-s" onclick="loadSpecPreset('mat')">🧶 素材・生地</button>
        <button class="btn btn-s" onclick="loadSpecPreset('all')">📋 全カテゴリ</button>
      </div>
    </div>
    <div id="check-area"><div class="empty-state"><div class="ei">🔍</div>仕様書をアップロードするか、プリセットを選択してください</div></div>
    <div class="card">
      <div class="card-title">カスタム項目を追加</div>
      <div style="display:grid;grid-template-columns:130px 1fr 1fr auto;gap:9px;align-items:end;">
        <div class="fg"><label>カテゴリ</label><select id="cc"><option value="刺繍・プリント">刺繍・プリント</option><option value="副資材">副資材</option><option value="縫製仕様">縫製仕様</option><option value="素材・生地">素材・生地</option><option value="その他">その他</option></select></div>
        <div class="fg"><label>項目名</label><input type="text" id="cn" placeholder="e.g. 胸刺繍 水平位置"></div>
        <div class="fg"><label>仕様値</label><input type="text" id="cs" placeholder="e.g. 前中心から右 5.0cm"></div>
        <button class="btn btn-s" onclick="addCustom()" style="align-self:flex-end;">＋ 追加</button>
      </div>
    </div>
    <div class="card">
      <div class="card-title">写真添付 &amp; AI 自動判定</div>
      <div class="upload-zone" id="sdz">
        <input type="file" id="spec-photo-input" multiple accept="image/*" onchange="handlePhotos(this.files,'spec')">
        <div class="uicon">📷</div><div class="utext">仕様確認写真をアップロード</div><div class="usub">刺繍・副資材・縫い目写真など</div>
      </div>
      <div class="pgrid" id="spgrid"></div>
      <div class="btn-row">
        <button class="btn btn-p" onclick="runSpecAI()">🤖 AI で仕様チェックを実行</button>
        <button class="btn btn-s" onclick="exportCSV('spec')">⬇ CSV出力</button>
      </div>
    </div>
    <div id="spec-result"></div>
  </div>

  <!-- ════════════════════════════════════
       MODE: 総合レポート
  ════════════════════════════════════ -->
  <div class="mode-panel" id="mode-sum">
    <div class="card">
      <div class="card-title">総合検品レポート</div>
      <div id="sum-content"><div class="empty-state"><div class="ei">📋</div>各タブで検品を実行後、ここに統合レポートが表示されます</div></div>
    </div>
    <div class="btn-row">
      <button class="btn btn-s" onclick="window.print()">🖨 印刷</button>
      <button class="btn btn-p" onclick="exportAll()">⬇ 全データ CSV</button>
    </div>
  </div>

</div><!-- /container -->

<script>
// ════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════
let dimPhotos=[], specPhotos=[], specItems=[], dimResults=null;
let measureState = {
  imageDataUrl: null,
  scaleCm: 8.56,
  scaleId: 'card',
  selectedParts: [],
  results: null
};

// ════════════════════════════════════════════════
// 計測部位定義
// ════════════════════════════════════════════════
const MEASURE_PARTS = [
  { id:'着丈',     label:'着丈',      desc:'後ろ衿付け根〜裾' },
  { id:'身幅',     label:'身幅',      desc:'脇下縫い目（直線）' },
  { id:'袖丈',     label:'袖丈',      desc:'肩縫い目〜袖口' },
  { id:'天巾',     label:'天巾',      desc:'衿ぐり幅（肩から肩）' },
  { id:'前下がり', label:'前下がり',  desc:'衿前中心の深さ' },
  { id:'裾幅',     label:'裾幅',      desc:'裾の開き幅' },
  { id:'袖口巾',   label:'袖口巾',    desc:'袖口の開き幅' },
  { id:'AH',       label:'AH(直線)',  desc:'アームホール直線' },
];

const MCOLORS = ['#e8c87a','#4caf78','#4a90d9','#e05252','#c87ae8','#78c8e8','#e8a84a','#a8e878'];

// ════════════════════════════════════════════════
// CLOCK
// ════════════════════════════════════════════════
setInterval(()=>{
  document.getElementById('clock').textContent=new Date().toLocaleTimeString('ja-JP',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
},1000);

// ════════════════════════════════════════════════
// MODE / STEP
// ════════════════════════════════════════════════
function switchMode(m){
  document.querySelectorAll('.mode-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.mode-tab').forEach(b=>b.classList.remove('active'));
  document.getElementById('mode-'+m).classList.add('active');
  [...document.querySelectorAll('.mode-tab')][['measure','dim','spec','sum'].indexOf(m)].classList.add('active');
  if(m==='sum') buildSummary();
  if(m==='dim') checkMeasureBanner();
}
function goStep(n){
  document.querySelectorAll('#mode-dim .panel').forEach((p,i)=>p.classList.toggle('active',i+1===n));
  document.querySelectorAll('#mode-dim .step-tab').forEach((t,i)=>{
    t.classList.remove('active','done');
    if(i+1===n)t.classList.add('active'); else if(i+1<n)t.classList.add('done');
  });
  window.scrollTo({top:0,behavior:'smooth'});
}

