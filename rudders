function initPartsGrid(){
  const grid=document.getElementById('parts-grid');
  grid.innerHTML='';
  measureState.selectedParts=MEASURE_PARTS.map(p=>p.id); // 全選択
  MEASURE_PARTS.forEach((p,i)=>{
    const div=document.createElement('div');
    div.className='part-chip sel';div.dataset.id=p.id;
    div.innerHTML=`<div class="pc-dot" style="background:${MCOLORS[i]}"></div><div><div>${p.label}</div><div style="font-size:9px;color:var(--text-muted);margin-top:1px;">${p.desc}</div></div>`;
    div.onclick=()=>togglePart(p.id,div);
    grid.appendChild(div);
  });
}

function togglePart(id,el){
  const idx=measureState.selectedParts.indexOf(id);
  if(idx>=0){measureState.selectedParts.splice(idx,1);el.classList.remove('sel');}
  else{measureState.selectedParts.push(id);el.classList.add('sel');}
}

function selectAllParts(sel){
  measureState.selectedParts=sel?MEASURE_PARTS.map(p=>p.id):[];
  document.querySelectorAll('.part-chip').forEach(el=>{
    el.classList.toggle('sel',sel);
  });
}

function handleMeasureFile(file){
  if(!file||!file.type.startsWith('image/'))return;
  const r=new FileReader();
  r.onload=e=>{
    measureState.imageDataUrl=e.target.result;
    document.getElementById('m-preview-img').src=e.target.result;
    document.getElementById('m-preview-wrap').style.display='block';
    document.getElementById('m-upload-zone').style.display='none';
    document.getElementById('m-run-btn').disabled=false;
  };
  r.readAsDataURL(file);
}

function resetMeasure(){
  measureState.imageDataUrl=null;
  document.getElementById('m-preview-wrap').style.display='none';
  document.getElementById('m-upload-zone').style.display='block';
  document.getElementById('m-run-btn').disabled=true;
  document.getElementById('m-result-area').style.display='none';
  document.getElementById('m-analyze-area').style.display='none';
}

function selectScale(el){
  document.querySelectorAll('.scale-opt').forEach(o=>o.classList.remove('sel'));
  el.classList.add('sel');
  measureState.scaleId=el.dataset.scaleId;
  measureState.scaleCm=parseFloat(el.dataset.scaleCm)||0;
  const cw=document.getElementById('custom-scale-wrap');
  if(el.dataset.scaleId==='custom') cw.classList.add('show');
  else cw.classList.remove('show');
}

async function runMeasure(){
  if(!measureState.imageDataUrl){alert('写真をアップロードしてください');return;}
  if(measureState.selectedParts.length===0){alert('計測部位を1つ以上選択してください');return;}
  if(measureState.scaleId==='custom'){
    const v=parseFloat(document.getElementById('custom-scale-input').value);
    if(!v){alert('カスタムスケールのcmを入力してください');return;}
    measureState.scaleCm=v;
  }

  document.getElementById('m-btn-row').style.display='none';
  document.getElementById('m-analyze-area').style.display='block';
  document.getElementById('m-result-area').style.display='none';
  document.getElementById('m-error-box').style.display='none';

  const log=document.getElementById('m-analyze-log');
  log.innerHTML='';
  function addLog(msg){const l=document.createElement('div');l.className='log-line';l.textContent=msg;log.appendChild(l);log.scrollTop=log.scrollHeight;}

  addLog('画像を前処理中...');
  await sleep(300);
  const scaleLabel=measureState.scaleId==='none'?'スケールなし（AI推定）':
    document.querySelector('.scale-opt.sel .scale-name')?.textContent||'スケール';
  if(measureState.scaleId!=='none') addLog(`スケール: ${scaleLabel} (${measureState.scaleCm}cm)`);
  await sleep(300);
  addLog(`計測部位: ${measureState.selectedParts.join('・')} — ${measureState.selectedParts.length}箇所`);
  await sleep(400);
  addLog('Claude Vision API に送信中...');

  try{
    const base64=measureState.imageDataUrl.split(',')[1];
    const mimeType=measureState.imageDataUrl.split(';')[0].split(':')[1];

    const scaleDesc=measureState.scaleId==='none'
      ?'写真内にスケールアイテムはありません。服のシルエットと一般的なアパレルサイズ感から実寸を推定してください。'
      :`写真内の基準スケール：${scaleLabel}（実寸 ${measureState.scaleCm}cm）`;

    const partsDesc=measureState.selectedParts.map((id,i)=>{
      const p=MEASURE_PARTS.find(x=>x.id===id);
      return `${i+1}. ${p.label}（${p.desc}）`;
    }).join('\n');

    const prompt=`あなたはアパレル服の採寸AIです。この画像は平置きされた服（トップス系）の写真です。
${scaleDesc}

以下の部位を計測してください：
${partsDesc}

【計測の注意事項】
- 着丈：後ろ衿付け根から裾まで（直線）
- 身幅：脇下縫い目の水平距離（片側）
- 袖丈：肩の縫い目から袖口縫い目まで
- 天巾：前衿ぐりの肩端から肩端（衿幅）
- 前下がり：前衿ぐりの最も深い点から肩ラインまでの垂直距離
- 裾幅：裾の端から端（片側）
- 袖口巾：袖口の開き幅（片側）
- AH直線：アームホールの縦の直線距離
${measureState.scaleId!=='none'?`- スケールアイテムのピクセル長さを計測し、1px = ${(measureState.scaleCm / 100).toFixed(4)}cm相当として実寸を計算してください`:'- 服全体のシルエットから典型的なアパレルサイズを参考に実寸を推定してください'}

以下のJSON形式のみで返答してください：
{
  "scale_found": ${measureState.scaleId!=='none'},
  "scale_px": 数値またはnull,
  "scale_cm": ${measureState.scaleCm},
  "px_per_cm": 数値またはnull,
  "measurements": [
    {
      "name": "部位名",
      "x1": 数値, "y1": 数値,
      "x2": 数値, "y2": 数値,
      "px_length": 数値,
      "cm_length": 数値,
      "confidence": "high"|"mid"|"low",
      "note": "備考（任意）"
    }
  ],
  "overall_note": "全体備考"
}`;

    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        messages:[{role:'user',content:[
          {type:'image',source:{type:'base64',media_type:mimeType,data:base64}},
          {type:'text',text:prompt}
        ]}]
      })
    });

    if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e?.error?.message||`HTTP ${res.status}`);}
    const data=await res.json();
    const text=data.content.find(b=>b.type==='text')?.text||'';
    addLog('レスポンス受信 — 解析中...');
    await sleep(200);

    const m=text.match(/\{[\s\S]*\}/);
    if(!m)throw new Error('AIのレスポンスを解析できませんでした');
    const json=JSON.parse(m[0]);

    addLog(`✓ ${json.measurements.length}箇所の計測完了`);
    await sleep(300);

    measureState.results=json;
    renderMeasureResults(json);
    document.getElementById('m-analyze-area').style.display='none';
    document.getElementById('m-result-area').style.display='block';
    document.getElementById('m-btn-row').style.display='flex';
    document.getElementById('m-run-btn').textContent='🔄 再実行';
    document.getElementById('m-run-btn').disabled=false;

  }catch(err){
    document.getElementById('m-analyze-area').style.display='none';
    document.getElementById('m-btn-row').style.display='flex';
    document.getElementById('m-run-btn').disabled=false;
    document.getElementById('m-error-box').style.display='block';
    document.getElementById('m-error-msg').textContent='エラー: '+err.message;
  }
}

function renderMeasureResults(r){
  const area=document.getElementById('m-result-area');

  // Canvas
  const img=new Image();
  img.onload=()=>{
    const canvasId='measure-canvas-'+Date.now();
    const scaleNote=r.scale_found
      ?`✓ スケール検出: ${r.scale_px?.toFixed(0)}px = ${r.scale_cm}cm → 1cm ≈ ${r.px_per_cm?.toFixed(1)}px`
      :'⚠ スケールなし（AI推定値）';

    let tableRows=r.measurements.map((m,i)=>{
      const isApprox=m.confidence!=='high';
      const cCls={high:'conf-high',mid:'conf-mid',low:'conf-low'}[m.confidence]||'conf-mid';
      const cLbl={high:'高精度',mid:'推定',low:'不明瞭'}[m.confidence]||'推定';
      return `<div class="mrow">
        <div class="mrow-name"><div class="mrow-color" style="background:${MCOLORS[i%MCOLORS.length]}"></div>${m.name}<span class="conf-badge ${cCls}">${cLbl}</span></div>
        <div class="mrow-px">${m.px_length?.toFixed(0)??'—'}px</div>
        <div class="mrow-cm ${isApprox?'approx':''}">${m.cm_length.toFixed(1)} cm</div>
        <div style="font-family:var(--mono);font-size:10px;color:var(--text-muted);text-align:right;">${m.note||''}</div>
      </div>`;
    }).join('');

    let legendHtml=r.measurements.map((m,i)=>`<div class="legend-item"><div class="legend-dot" style="background:${MCOLORS[i%MCOLORS.length]}"></div>${m.name}</div>`).join('');

    area.innerHTML=`
      <div class="import-banner">
        <div>
          <div class="import-banner-text">✅ 採寸完了 — ${r.measurements.length}部位を計測</div>
          <div class="import-banner-sub">「寸法検品」タブで指示寸として取り込めます</div>
        </div>
        <button class="btn btn-green" onclick="switchMode('dim');setTimeout(()=>{goStep(2);checkMeasureBanner();},100)">寸法検品に取り込む →</button>
      </div>
      <div class="measure-result-wrap">
        <canvas id="${canvasId}" style="width:100%;display:block;max-height:400px;object-fit:contain;background:#0a0a0a;"></canvas>
        <div class="measure-canvas-legend">${legendHtml}</div>
      </div>
      <div class="scale-note ${r.scale_found?'ok':'warn'}">${scaleNote}</div>
      <div class="measure-table-wrap">
        <div class="mtable-header"><span>計測箇所</span><span style="text-align:right">px長さ</span><span style="text-align:right">実寸(cm)</span><span></span></div>
        ${tableRows}
      </div>
      <div class="btn-row">
        <button class="btn btn-s" onclick="exportMeasureCSV()">⬇ CSV出力</button>
        <button class="btn btn-s" onclick="exportMeasureImage('${canvasId}')">⬇ 注釈画像</button>
      </div>
    `;

    // Draw on canvas
    const canvas=document.getElementById(canvasId);
    const ctx=canvas.getContext('2d');
    const maxW=Math.min(img.width,1200);
    const sc=maxW/img.width;
    canvas.width=img.width*sc;canvas.height=img.height*sc;
    ctx.drawImage(img,0,0,canvas.width,canvas.height);

    r.measurements.forEach((m,i)=>{
      const color=MCOLORS[i%MCOLORS.length];
      ctx.beginPath();ctx.moveTo(m.x1*sc,m.y1*sc);ctx.lineTo(m.x2*sc,m.y2*sc);
      ctx.strokeStyle=color;ctx.lineWidth=2.5;ctx.setLineDash([]);ctx.stroke();
      [[m.x1*sc,m.y1*sc],[m.x2*sc,m.y2*sc]].forEach(([x,y])=>{
        ctx.beginPath();ctx.arc(x,y,5,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();
        ctx.beginPath();ctx.arc(x,y,5,0,Math.PI*2);ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();
      });
      const mx=((m.x1+m.x2)/2)*sc,my=((m.y1+m.y2)/2)*sc;
      const label=`${m.name} ${m.cm_length.toFixed(1)}cm`;
      ctx.font='bold 12px monospace';
      const tw=ctx.measureText(label).width;
      ctx.fillStyle='rgba(0,0,0,0.72)';ctx.fillRect(mx-tw/2-6,my-10,tw+12,20);
      ctx.fillStyle=color;ctx.fillText(label,mx-tw/2,my+4);
    });
  };
  img.src=measureState.imageDataUrl;
}

// 採寸結果を寸法検品に取り込む
function checkMeasureBanner(){
  const banner=document.getElementById('measure-import-banner');
  if(banner) banner.style.display=measureState.results?'flex':'none';
}

function importFromMeasure(){
  if(!measureState.results)return;
  const tbody=document.getElementById('spec-tbody');
  tbody.innerHTML='';
  measureState.results.measurements.forEach(m=>{
    const p=MEASURE_PARTS.find(x=>x.id===m.name||x.label===m.name);
    addSpecRow(m.name, p?p.desc:'', m.cm_length.toFixed(1));
  });
  toast(`${measureState.results.measurements.length}部位の採寸値を指示寸として取り込みました ✓`);
}

function exportMeasureCSV(){
  if(!measureState.results)return;
  const rows=[['部位','px長さ','実寸(cm)','信頼度','備考'],...measureState.results.measurements.map(m=>[m.name,m.px_length?.toFixed(0),m.cm_length.toFixed(1),m.confidence,m.note||''])];
  dl(rows,`RUDDERS_採寸_${new Date().toISOString().slice(0,10)}.csv`);
}
function exportMeasureImage(canvasId){
  const c=document.getElementById(canvasId);if(!c)return;
  const a=document.createElement('a');a.href=c.toDataURL('image/jpeg',0.92);a.download=`RUDDERS_採寸_${Date.now()}.jpg`;a.click();
}

