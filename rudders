  let html=`<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:9px;margin-bottom:18px;font-family:var(--mono);font-size:11px;">`;
  [['品番',meta.itemNo],['品名',meta.itemName],['サイズ',meta.size],['カラー',meta.color],['担当',meta.inspector],['日付',meta.date]].forEach(([k,v])=>{if(!v)return;html+=`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:9px 11px;"><div style="color:var(--text-muted);font-size:9px;letter-spacing:0.1em;text-transform:uppercase;">${k}</div><div style="margin-top:2px;color:var(--text)">${v}</div></div>`;});
  html+=`</div>`;
  if(hasMeasure){
    html+=`<div style="margin-bottom:7px;font-family:var(--mono);font-size:10px;letter-spacing:0.12em;color:var(--accent);text-transform:uppercase;">📐 AI採寸 — ${measureState.results.measurements.length}部位</div>`;
    html+=`<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:6px;margin-bottom:16px;">`;
    measureState.results.measurements.forEach((m,i)=>{html+=`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:8px 11px;"><div style="font-size:9px;color:var(--text-muted);font-family:var(--mono);">${m.name}</div><div style="font-size:15px;font-weight:500;color:${MCOLORS[i%MCOLORS.length]};font-family:var(--mono);">${m.cm_length.toFixed(1)}<span style="font-size:10px;opacity:0.6"> cm</span></div></div>`;});
    html+=`</div>`;
  }
  if(hasDim){const dr=dimResults.parsed.inspection_results||[];const dp=dr.filter(r=>r.status==='合格').length,df=dr.filter(r=>r.status==='不合格').length;html+=`<div style="margin-bottom:7px;font-family:var(--mono);font-size:10px;letter-spacing:0.12em;color:var(--accent);text-transform:uppercase;">📏 寸法検品 — 合格 ${dp} / 不合格 ${df}</div>`;dr.filter(r=>r.status==='不合格').forEach(r=>{html+=`<div style="padding:7px 13px;background:var(--fail-dim);border:1px solid rgba(224,82,82,0.2);border-radius:6px;margin-bottom:5px;font-size:12px;"><span style="color:var(--fail);font-family:var(--mono);">✕ ${r.item}</span> — 指示寸 ${r.spec_value??'—'}cm / 実寸 ${r.actual_value??'—'}cm / 差分 ${r.diff!==null?(parseFloat(r.diff)>=0?'+':'')+parseFloat(r.diff).toFixed(1):'—'}cm</div>`;});}
  if(hasSpec){const sp=specItems.filter(i=>i.status==='合格').length,sf=specItems.filter(i=>i.status==='不合格').length;html+=`<div style="margin:14px 0 7px;font-family:var(--mono);font-size:10px;letter-spacing:0.12em;color:var(--accent);text-transform:uppercase;">🔍 仕様チェック — 合格 ${sp} / 不合格 ${sf}</div>`;specItems.filter(i=>i.status==='不合格').forEach(item=>{html+=`<div style="padding:7px 13px;background:var(--fail-dim);border:1px solid rgba(224,82,82,0.2);border-radius:6px;margin-bottom:5px;font-size:12px;"><span style="color:var(--fail);font-family:var(--mono);">✕ [${item.cat}] ${item.name}</span><br><span style="font-size:11px;color:var(--text-dim)">${item.spec} / ${item.note||'コメントなし'}</span></div>`;});}
  area.innerHTML=html;
}

// ════════════════════════════════════════════════
// CSV
// ════════════════════════════════════════════════
function exportCSV(type){
  const meta={itemNo:document.getElementById('item-no').value,itemName:document.getElementById('item-name').value,size:document.getElementById('item-size').value,inspector:document.getElementById('inspector').value};
  let rows=[],header=[];
  if(type==='dim'&&dimResults){header=['品番','品名','サイズ','担当者','計測箇所','指示寸(cm)','実寸(cm)','差分(cm)','判定','コメント','検品日'];rows=(dimResults.parsed.inspection_results||[]).map(r=>[meta.itemNo,meta.itemName,meta.size,meta.inspector,r.item,r.spec_value??'',r.actual_value??'',r.diff??'',r.status,r.comment??'',new Date().toLocaleDateString('ja-JP')]);}
  else if(type==='spec'){header=['品番','品名','サイズ','担当者','カテゴリ','項目名','仕様値','判定','コメント','検品日'];rows=specItems.map(i=>[meta.itemNo,meta.itemName,meta.size,meta.inspector,i.cat,i.name,i.spec,i.status,i.note,new Date().toLocaleDateString('ja-JP')]);}
  if(!rows.length){alert('出力データがありません');return;}
  dl([header,...rows],`検品_${type}_${meta.itemNo||'RUDDERS'}_${new Date().toISOString().slice(0,10)}.csv`);
}
function exportAll(){
  const meta={itemNo:document.getElementById('item-no').value,itemName:document.getElementById('item-name').value,size:document.getElementById('item-size').value,inspector:document.getElementById('inspector').value};
  const h=['種別','品番','品名','サイズ','担当者','箇所/項目','仕様値','実寸','差分','判定','コメント','検品日'];const rows=[];
  if(measureState.results) measureState.results.measurements.forEach(m=>rows.push(['採寸',meta.itemNo,meta.itemName,meta.size,meta.inspector,m.name,'',m.cm_length.toFixed(1),'',m.confidence,m.note||'',new Date().toLocaleDateString('ja-JP')]));
  if(dimResults)(dimResults.parsed.inspection_results||[]).forEach(r=>rows.push(['寸法',meta.itemNo,meta.itemName,meta.size,meta.inspector,r.item,r.spec_value??'',r.actual_value??'',r.diff??'',r.status,r.comment??'',new Date().toLocaleDateString('ja-JP')]));
  specItems.forEach(i=>rows.push(['仕様',meta.itemNo,meta.itemName,meta.size,meta.inspector,`[${i.cat}] ${i.name}`,i.spec,'','',i.status||'未判定',i.note,new Date().toLocaleDateString('ja-JP')]));
  if(!rows.length){alert('出力データがありません');return;}
  dl([h,...rows],`総合検品_${meta.itemNo||'RUDDERS'}_${new Date().toISOString().slice(0,10)}.csv`);
}
function dl(data,fname){
  const csv='\uFEFF'+data.map(r=>r.map(v=>`"${String(v||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));a.download=fname;a.click();
}

