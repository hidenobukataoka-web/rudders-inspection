    content.push({type:'text',text:`プロのアパレル検品技術者として仕様書と検品写真（メジャー付き）を照合してください。品番:${meta.itemNo} 品名:${meta.itemName} サイズ:${meta.size} 許容範囲:±${tol}cm\n【仕様書】\n${st}\nJSONのみ返答:{"inspection_results":[{"item":"","spec_value":null,"actual_value":null,"diff":null,"status":"合格"or"不合格"or"判定不可","comment":""}],"overall_verdict":"合格"or"不合格"or"要確認","summary_comment":""}`});
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content}]})});
    const data=await res.json();
    const raw=data.content.map(c=>c.text||'').join('');
    const clean=raw.replace(/```json|```/g,'').trim();
    const parsed=JSON.parse(clean.substring(clean.indexOf('{'),clean.lastIndexOf('}')+1));
    dimResults={parsed,meta,tol};
    renderDimResults(parsed,meta,tol);
    document.getElementById('result-actions').style.display='flex';
  }catch(err){
    area.innerHTML=`<div class="card"><div class="ai-status"><div class="ai-dot error"></div><span>エラー: ${err.message}</span></div></div>`;
    renderManual(rows,tol,meta);
